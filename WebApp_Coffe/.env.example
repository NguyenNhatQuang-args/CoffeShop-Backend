# ================================
# CoffeeShop Backend — Environment
# ================================
# Copy this to appsettings.Development.json and fill in real values.
# NEVER commit real secrets to git.

# --- Supabase PostgreSQL ---
# Format: Host=xxx.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true
DB_CONNECTION_STRING=

# --- JWT Authentication ---
# Must be at least 32 characters
JWT_SECRET_KEY=

# --- Admin seed account ---
# Default: Admin@123 (see Data/Configurations/UserConfiguration.cs)
